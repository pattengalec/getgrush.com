<script>
(function(){
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var $  = function(s,r){ return (r||document).querySelector(s); };
  var $$ = function(s,r){ return Array.prototype.slice.call((r||document).querySelectorAll(s)); };

  var mapSvg   = $('.weave svg');
  var weave    = $('.weave');
  var legendEl = $('.legend');
  var intro    = $('#intro');
  var stage    = $('#stage');
  var skipBtn  = $('#skip');
  var capEl    = $('#caption');
  var pageEl   = $('#page');
  var VB = { w:1100, h:620 };

  /* ---------- ambient filaments ---------- */
  var fil = $('#filaments');
  var seedPts = [[410,145],[790,195],[430,380],[570,275],[940,480],[388,520]];
  var rnd = function(a,b){ return a + Math.random()*(b-a); };
  seedPts.forEach(function(p){
    for (var i=0;i<7;i++){
      var ang = rnd(0, Math.PI*2), len = rnd(18,52);
      var x2 = p[0] + Math.cos(ang)*len, y2 = p[1] + Math.sin(ang)*len;
      var mx = p[0] + Math.cos(ang)*len*0.5 + rnd(-9,9);
      var my = p[1] + Math.sin(ang)*len*0.5 + rnd(-9,9);
      var path = document.createElementNS('http://www.w3.org/2000/svg','path');
      path.setAttribute('class','filament');
      path.setAttribute('d','M'+p[0]+','+p[1]+' Q'+mx.toFixed(1)+','+my.toFixed(1)+' '+x2.toFixed(1)+','+y2.toFixed(1));
      fil.appendChild(path);
    }
  });

  var cords   = $$('#cords .hypha');
  var strands = $$('.filament');
  var DASH    = { dormant:'3 7', owns:'1 5', reach:'2 6' };
  function restDash(p){ for (var k in DASH){ if (p.classList.contains(k)) return DASH[k]; } return null; }
  function byPair(n){ return cords.filter(function(c){ return c.getAttribute('data-pair')===n; })[0]; }

  /* ---------- node hover: light the cords ---------- */
  $$('g.node').forEach(function(n){
    var list = (n.getAttribute('data-cords')||'').split(' ').filter(Boolean);
    var mine = cords.filter(function(c){ return list.indexOf(c.getAttribute('data-pair'))!==-1; });
    function on(){ mine.forEach(function(c){ c.classList.add('hot'); }); }
    function off(){ mine.forEach(function(c){ c.classList.remove('hot'); }); }
    n.addEventListener('mouseenter',on); n.addEventListener('mouseleave',off);
    n.addEventListener('focus',on);      n.addEventListener('blur',off);
    function go(){
      var t = n.getAttribute('data-go'); var el = t && $(t);
      if (el) el.scrollIntoView({behavior: reduce ? 'auto':'smooth', block:'start'});
    }
    n.addEventListener('click',go);
    n.addEventListener('keydown',function(e){
      if (e.key==='Enter'||e.key===' '){ e.preventDefault(); go(); }
    });
  });

  /* ---------- drawing helpers ---------- */
  function len(p){ try { return p.getTotalLength(); } catch(e){ return 0; } }
  function hide(p){
    var L = len(p); if(!L) return;
    p.style.strokeDasharray = L+' '+L;
    p.style.strokeDashoffset = L;
    p.style.transition = 'none';
  }
  function draw(p, dur, delay){
    var L = len(p); if(!L) return;
    p.style.transition = 'stroke-dashoffset '+dur+'ms cubic-bezier(.22,.61,.36,1) '+(delay||0)+'ms';
    p.style.strokeDashoffset = '0';
    var rest = restDash(p);
    if (rest){ setTimeout(function(){ if(!killed){ p.style.strokeDasharray = rest; p.style.strokeDashoffset='0'; } }, dur+(delay||0)); }
  }
  function drawAll(list, dur, stagger){
    list.forEach(function(p,i){ draw(p, dur, i*(stagger||0)); });
  }
  function fade(el, to, dur){
    if(!el) return;
    el.style.transition = 'opacity '+(dur||600)+'ms ease';
    el.style.opacity = to;
  }
  function show(el){ if(el){ el.style.transition='opacity 700ms ease'; el.style.opacity=1; } }

  /* ---------- camera ---------- */
  var cam = { x:0, y:0, w:VB.w, h:VB.h };
  function applyCam(){ mapSvg.setAttribute('viewBox', cam.x+' '+cam.y+' '+cam.w+' '+cam.h); }
  function easeInOut(t){ return t<.5 ? 4*t*t*t : 1-Math.pow(-2*t+2,3)/2; }
  function moveCam(cx, cy, zoom, dur){
    return new Promise(function(res){
      var w1 = VB.w/zoom, h1 = VB.h/zoom;
      var to = { x: cx-w1/2, y: cy-h1/2, w: w1, h: h1 };
      var fr = { x:cam.x, y:cam.y, w:cam.w, h:cam.h };
      var t0 = performance.now();
      (function step(now){
        if (killed){ res(); return; }
        var t = Math.min(1,(now-t0)/dur), e = easeInOut(t);
        cam.x = fr.x+(to.x-fr.x)*e; cam.y = fr.y+(to.y-fr.y)*e;
        cam.w = fr.w+(to.w-fr.w)*e; cam.h = fr.h+(to.h-fr.h)*e;
        applyCam();
        if (t<1) requestAnimationFrame(step); else res();
      })(t0);
    });
  }

  /* ---------- traffic along a guide path ---------- */
  function traffic(guide, dot, dur, reverse, loops){
    return new Promise(function(res){
      var L = len(guide); if(!L){ res(); return; }
      var n = 0;
      dot.setAttribute('opacity','1');
      var t0 = performance.now();
      (function step(now){
        if (killed){ res(); return; }
        var t = ((now-t0)%dur)/dur;
        var d = reverse ? (1-t)*L : t*L;
        var pt = guide.getPointAtLength(d);
        dot.setAttribute('cx',pt.x); dot.setAttribute('cy',pt.y);
        var edge = Math.min(t,1-t)*2;
        dot.setAttribute('opacity', Math.min(1, edge*3).toFixed(2));
        if ((now-t0) < dur*loops) requestAnimationFrame(step);
        else { dot.setAttribute('opacity','0'); res(); }
      })(t0);
    });
  }

  /* ---------- sequencer ---------- */
  var killed = false;
  var timers = [];
  function wait(ms){
    return new Promise(function(res){
      if (killed) return res();
      var id = setTimeout(res, ms); timers.push(id);
    });
  }
  function caption(txt){
    if (!txt){ capEl.classList.remove('on'); return; }
    capEl.innerHTML = txt; capEl.classList.add('on');
  }

  /* ---------- initial hidden state ---------- */
  var mapBits = {
    boundary : $('.boundary'),
    spheres  : $$('.sphere-label'),
    edges    : $$('.edge-label'),
    nodes    : $$('g.node'),
    hub      : $$('.hub-ring, .hub-core, .hub-label')
  };
  function armIntro(){
    cords.concat(strands).forEach(hide);
    mapBits.nodes.forEach(function(n){ n.style.opacity = 0; });
    mapBits.hub.forEach(function(n){ n.style.opacity = 0; });
    mapBits.spheres.forEach(function(n){ n.style.opacity = 0; });
    mapBits.edges.forEach(function(n){ n.style.opacity = 0; });
    if (mapBits.boundary) mapBits.boundary.style.opacity = 0;
    if (legendEl) legendEl.style.opacity = 0;
  }
  function settleAll(){
    cords.concat(strands).forEach(function(p){
      p.style.transition='none';
      var rest = restDash(p);
      p.style.strokeDasharray = rest || 'none';
      p.style.strokeDashoffset = '0';
    });
    [].concat(mapBits.nodes, mapBits.hub, mapBits.spheres, mapBits.edges,
             mapBits.boundary?[mapBits.boundary]:[], legendEl?[legendEl]:[])
      .forEach(function(n){ if(n){ n.style.transition='opacity 500ms ease'; n.style.opacity=1; } });
    cam = { x:0, y:0, w:VB.w, h:VB.h }; applyCam();
  }

  /* ---------- scene A: the membrane ---------- */
  async function sceneMembrane(){
    var s = $('#sceneA');
    ['#A_wall','#A_plasma','#A_hypha','#A_pen'].forEach(function(id){ hide($(id)); });
    $$('#A_arb path').forEach(hide); $$('#A_peri path').forEach(hide);
    $('#A_labels').style.opacity = 0;

    s.classList.add('on');
    await wait(500);
    draw($('#A_wall'), 900); if(killed) return;
    caption('the hypha arrives');
    draw($('#A_hypha'), 1000, 200);
    await wait(1300); if(killed) return;

    caption('it presses through the wall');
    draw($('#A_pen'), 700);
    await wait(700); if(killed) return;

    caption('the host membrane <b>invaginates &mdash; it does not break</b>');
    draw($('#A_plasma'), 1900);
    await wait(1000); if(killed) return;

    drawAll($$('#A_arb path'), 700, 90);
    await wait(1500); if(killed) return;

    caption('the arbuscule branches <b>inside an unbroken wall</b>');
    drawAll($$('#A_peri path'), 800, 100);
    show($('#A_labels'));
    await wait(1100); if(killed) return;

    caption('phosphorus in &middot; carbon out &middot; <b>nothing fuses</b>');
    var g = $('#A_guide');
    traffic(g, $('#p1'), 2600, false, 2.6);
    setTimeout(function(){ if(!killed) traffic(g, $('#p2'), 2600, false, 2.0); }, 900);
    traffic(g, $('#c1'), 3000, true, 2.6);
    setTimeout(function(){ if(!killed) traffic(g, $('#c2'), 3000, true, 2.0); }, 1300);
    await wait(3000); if(killed) return;

    caption('');
    s.classList.remove('on');
    await wait(700);
  }

  /* ---------- scene B: the reach ---------- */
  async function sceneReach(){
    var s = $('#sceneB');
    hide($('#B_root')); hide($('#B_main'));
    $$('#B_sig_out path').forEach(hide);
    $$('#B_branch path').forEach(hide);
    ['#B_labels','#B_myc_label','#B_gap','#B_sig_in'].forEach(function(id){ $(id).style.opacity = 0; });
    $('#B_field').style.opacity = 0;
    $('#B_spore').setAttribute('opacity','0');

    s.classList.add('on');
    await wait(500);
    draw($('#B_root'), 900); if(killed) return;

    caption('the root releases <b>strigolactones</b>');
    fade($('#B_field'), 1, 1400);
    drawAll($$('#B_sig_out path'), 900, 160);
    await wait(1500); if(killed) return;

    caption('a spore germinates');
    $('#B_spore').setAttribute('opacity','1');
    await wait(600); if(killed) return;

    caption('the hypha grows <b>toward the signal</b>');
    draw($('#B_main'), 1600);
    await wait(1700); if(killed) return;

    caption('branching intensifies as it nears');
    drawAll($$('#B_branch path'), 600, 90);
    show($('#B_labels'));
    await wait(1400); if(killed) return;

    caption('the fungus answers with <b>Myc factors</b>');
    show($('#B_sig_in')); show($('#B_myc_label'));
    await wait(1400); if(killed) return;

    caption('and there it stops. <b>no contact.</b>');
    show($('#B_gap'));
    await wait(2000); if(killed) return;

    caption('');
    s.classList.remove('on');
    await wait(700);
  }

  /* ---------- the sequence ---------- */
  async function run(){
    document.body.classList.add('intro-running');
    intro.hidden = false; skipBtn.hidden = false;
    pageEl.classList.add('hidden');
    stage.insertBefore(mapSvg, stage.firstChild);
    armIntro(); applyCam();
    await wait(400); if(killed) return;

    // 1. the spore
    caption('one spore');
    mapBits.hub.forEach(function(n){ n.style.transition='opacity 900ms ease'; n.style.opacity=1; });
    await wait(1300); if(killed) return;

    // 2. germination -> the three ventures
    caption('it reaches for what it needs');
    draw(byPair('hub-fungai'), 1100);
    draw(byPair('hub-fgf'), 1100, 150);
    draw(byPair('hub-soft'), 1100, 300);
    await wait(700); if(killed) return;
    [ $$('g.node')[2], $$('g.node')[3], $$('g.node')[4] ].forEach(function(n,i){
      if(!n) return; n.style.transition='opacity 700ms ease '+(i*160)+'ms'; n.style.opacity=1;
    });
    await wait(1400); if(killed) return;

    // 3. the loop closes
    caption('each one feeds the other two');
    draw(byPair('fungai-fgf'), 1000);
    draw(byPair('fgf-soft'), 1000, 200);
    draw(byPair('soft-fungai'), 1000, 400);
    await wait(1700); if(killed) return;

    // 4. the deployment
    caption('the software goes to work');
    draw(byPair('soft-lancer'), 800);
    await wait(500); if(killed) return;
    var lancer = $$('g.node').filter(function(n){ return n.classList.contains('is-deploy'); })[0];
    if (lancer){ lancer.style.transition='opacity 700ms ease'; lancer.style.opacity=1; }
    await wait(1000); if(killed) return;

    // 5. the other sphere
    caption('but the garden belongs to someone else');
    show(mapBits.boundary);
    mapBits.spheres.forEach(function(n){ n.style.transition='opacity 800ms ease'; n.style.opacity=1; });
    $$('g.node.is-external').forEach(function(n,i){
      n.style.transition='opacity 700ms ease '+(i*200)+'ms'; n.style.opacity=1;
    });
    draw(byPair('cbu-garden'), 900, 300);
    await wait(1800); if(killed) return;

    // 6. the crossing
    caption('one cord crosses the membrane');
    draw(byPair('garden-deploy'), 1300);
    await wait(1500); if(killed) return;

    // 7. push in -> SCENE A
    caption('');
    await moveCam(270, 508, 7.5, 1500); if(killed) return;
    await sceneMembrane(); if(killed) return;
    await moveCam(550, 310, 1, 1500); if(killed) return;

    // 8. the reach
    caption('elsewhere, it reaches');
    draw(byPair('fungai-cbu'), 1400);
    await wait(1600); if(killed) return;

    // 9. push in -> SCENE B
    caption('');
    await moveCam(292, 212, 7.5, 1500); if(killed) return;
    await sceneReach(); if(killed) return;
    await moveCam(550, 310, 1, 1500); if(killed) return;

    // 10. what waits
    caption('and something waits downstream');
    $$('#cords .hypha.dormant').forEach(function(p,i){ draw(p, 1100, i*160); });
    var dorm = $$('g.node.is-dormant')[0];
    if (dorm){ dorm.style.transition='opacity 900ms ease'; dorm.style.opacity=1; }
    await wait(1800); if(killed) return;

    // 11. settle
    caption('');
    drawAll(strands, 900, 25);
    mapBits.edges.forEach(function(n){ n.style.transition='opacity 700ms ease'; n.style.opacity=1; });
    await wait(900); if(killed) return;
    finish();
  }

  function finish(){
    if (killed) return;
    killed = true;
    timers.forEach(clearTimeout);
    try { localStorage.setItem('grush_intro_seen','1'); } catch(e){}
    settleAll();
    $('#sceneA').classList.remove('on'); $('#sceneB').classList.remove('on');
    caption('');
    weave.insertBefore(mapSvg, legendEl);
    intro.classList.add('gone'); skipBtn.classList.add('gone');
    pageEl.classList.remove('hidden');
    document.body.classList.remove('intro-running');
    setTimeout(function(){ intro.hidden = true; skipBtn.hidden = true; }, 1200);
  }

  skipBtn.addEventListener('click', finish);
  document.addEventListener('keydown', function(e){
    if (!intro.hidden && (e.key==='Escape' || e.key===' ')){ e.preventDefault(); finish(); }
  });

  /* ---------- decide ---------- */
  var seen = false;
  try { seen = !!localStorage.getItem('grush_intro_seen'); } catch(e){}
  if (reduce || seen){
    settleAll();
    intro.hidden = true; skipBtn.hidden = true;
  } else {
    run();
  }
})();
</script>

</body>
</html>
