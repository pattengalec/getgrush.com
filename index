<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Grush</title>
<meta name="description" content="Grush is an umbrella for four ventures: Grush software, Fun Guy Fungi, fungAI, and Cottages.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --substrate:#14110F;
    --substrate-2:#1C1815;
    --substrate-3:#252019;
    --mycelium:#E8E1D4;
    --mycelium-dim:#948B7E;
    --mycelium-faint:#5A5248;
    --oxblood:#8C2F39;
    --oxblood-lit:#B84450;
    --steel:#5C7080;
    --steel-lit:#8AA6B8;
    --spore:#C9A227;
    --hairline:#302A24;
    --display:'Fraunces',Georgia,serif;
    --body:'IBM Plex Sans',system-ui,sans-serif;
    --mono:'IBM Plex Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--substrate);
    color:var(--mycelium);
    font-family:var(--body);
    font-weight:300;
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
  }
  ::selection{background:var(--oxblood);color:var(--mycelium)}
  a{color:inherit}
  .wrap{max-width:1080px;margin:0 auto;padding:0 28px}

  /* ---------- masthead ---------- */
  .masthead{
    display:flex;align-items:baseline;justify-content:space-between;
    padding:26px 0;border-bottom:1px solid var(--hairline);
  }
  .wordmark{
    font-family:var(--display);font-weight:600;font-size:26px;
    letter-spacing:.14em;text-transform:uppercase;
  }
  .masthead .meta{
    font-family:var(--mono);font-size:11px;letter-spacing:.1em;
    text-transform:uppercase;color:var(--mycelium-dim);
  }

  /* ---------- hero ---------- */
  .hero{padding:64px 0 48px}
  .eyebrow{
    font-family:var(--mono);font-size:11px;letter-spacing:.18em;
    text-transform:uppercase;color:var(--spore);margin-bottom:22px;
  }
  .thesis{
    font-family:var(--display);
    font-weight:300;
    font-size:clamp(30px,5.2vw,52px);
    line-height:1.16;
    letter-spacing:-.015em;
    max-width:19ch;
  }
  .thesis em{font-style:italic;color:var(--spore)}
  .sub{
    margin-top:24px;max-width:56ch;color:var(--mycelium-dim);
    font-size:16.5px;
  }

  /* ---------- the web ---------- */
  .weave{margin:16px 0 8px;position:relative}
  .weave svg{width:100%;height:auto;display:block;overflow:visible}
  .hypha{
    fill:none;stroke:var(--mycelium-faint);stroke-width:1.1;
    stroke-linecap:round;transition:stroke .35s ease,stroke-width .35s ease;
  }
  .hypha.dormant{stroke-dasharray:3 7;stroke:var(--hairline)}
  .hypha.hot{stroke:var(--oxblood-lit);stroke-width:1.8}
  .hypha.owns{
    stroke:var(--steel);stroke-width:1;stroke-dasharray:1 5;
  }
  .hypha.owns.hot{stroke:var(--steel-lit);stroke-width:1.6}
  .hypha.reach{
    stroke:var(--steel);stroke-width:1;opacity:.5;
    stroke-dasharray:2 6;
  }
  .hypha.reach.hot{stroke:var(--steel-lit);opacity:1;stroke-width:1.4}
  .hypha.exchange{stroke:var(--spore);stroke-width:1.3;opacity:.85}
  .hypha.exchange.hot{stroke:var(--spore);stroke-width:2;opacity:1}
  .sphere-label{
    font-family:var(--mono);font-size:9.5px;letter-spacing:.16em;
    text-transform:uppercase;fill:var(--mycelium-faint);
  }
  .edge-label{
    font-family:var(--mono);font-size:9px;letter-spacing:.13em;
    text-transform:uppercase;fill:var(--mycelium-faint);
  }
  .boundary{
    fill:none;stroke:var(--hairline);stroke-width:1;stroke-dasharray:6 8;
  }
  .boundary-label{
    font-family:var(--mono);font-size:9px;letter-spacing:.14em;
    text-transform:uppercase;fill:var(--mycelium-faint);
  }
  .filament{fill:none;stroke:var(--hairline);stroke-width:.6;stroke-linecap:round}
  .node-hit{cursor:pointer;fill:transparent}
  .node-ring{
    fill:var(--substrate);stroke:var(--mycelium-faint);stroke-width:1.2;
    transition:stroke .3s ease,fill .3s ease;
  }
  .node-core{fill:var(--mycelium-dim);transition:fill .3s ease,r .3s ease}
  .node-label{
    font-family:var(--mono);font-size:11.5px;letter-spacing:.07em;
    fill:var(--mycelium-dim);transition:fill .3s ease;
  }
  .node-role{
    font-family:var(--mono);font-size:9px;letter-spacing:.14em;
    text-transform:uppercase;fill:var(--mycelium-faint);
  }
  g.node:hover .node-ring,g.node:focus-visible .node-ring{stroke:var(--spore)}
  g.node:hover .node-core,g.node:focus-visible .node-core{fill:var(--spore)}
  g.node:hover .node-label,g.node:focus-visible .node-label{fill:var(--mycelium)}
  g.node:focus-visible{outline:none}
  g.node:focus-visible .node-ring{stroke-width:2}
  .hub-ring{fill:var(--substrate);stroke:var(--oxblood);stroke-width:1.6}
  .hub-core{fill:var(--oxblood)}
  .hub-label{
    font-family:var(--display);font-weight:600;font-size:15px;
    letter-spacing:.16em;fill:var(--mycelium);text-transform:uppercase;
  }
  .node.is-dormant .node-ring{stroke:var(--hairline)}
  .node.is-dormant .node-core{fill:var(--hairline)}
  .node.is-dormant .node-label{fill:var(--mycelium-faint)}

  /* deployment nodes */
  .node.is-deploy .node-core{fill:var(--mycelium-faint)}
  .node.is-deploy.is-live .node-core{fill:var(--spore)}
  .node.is-deploy.is-live .node-ring{stroke:var(--spore);opacity:.7}
  .dual-ring{
    fill:none;stroke:var(--mycelium-faint);stroke-width:.9;opacity:.55;
  }

  /* external entity */
  .node.is-external .ext-box{
    fill:var(--substrate);stroke:var(--steel);stroke-width:1.1;
    stroke-dasharray:3 3;transition:stroke .3s ease;
  }
  .node.is-external .node-core{fill:var(--steel)}
  .node.is-external .node-label{fill:var(--steel-lit)}
  .node.is-external:hover .ext-box,
  .node.is-external:focus-visible .ext-box{stroke:var(--steel-lit);stroke-dasharray:none}
  .node.is-external:hover .node-core{fill:var(--steel-lit)}

  /* legend */
  .legend{
    display:flex;flex-wrap:wrap;gap:10px 22px;
    padding:18px 0 4px;
    font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;
    color:var(--mycelium-faint);text-transform:uppercase;
  }
  .legend span{display:flex;align-items:center;gap:8px}
  .key{width:11px;height:11px;border-radius:50%;border:1px solid var(--mycelium-faint);flex:none}
  .key.venture{background:transparent}
  .key.dual{box-shadow:0 0 0 2.5px var(--substrate),0 0 0 3.5px var(--mycelium-faint)}
  .key.live{border-color:var(--spore);background:var(--spore)}
  .key.ext{border-radius:1px;border-color:var(--steel);border-style:dashed}
  .key.paused{border-color:var(--hairline);border-style:dashed}

  /* ---------- loop ---------- */
  .loop{
    border-top:1px solid var(--hairline);
    border-bottom:1px solid var(--hairline);
    padding:38px 0;margin-top:40px;
  }
  .loop-line{
    font-family:var(--display);font-weight:300;
    font-size:clamp(17px,2.3vw,22px);line-height:1.55;max-width:60ch;
  }
  .loop-line b{font-weight:600;color:var(--spore)}

  /* ---------- branches ---------- */
  .branches{padding:8px 0 0}
  .branch{
    padding:44px 0;border-bottom:1px solid var(--hairline);
    display:grid;grid-template-columns:150px 1fr;gap:36px;align-items:start;
  }
  .branch-role{
    font-family:var(--mono);font-size:10.5px;letter-spacing:.16em;
    text-transform:uppercase;color:var(--mycelium-faint);padding-top:9px;
  }
  .branch-role .tag{
    display:inline-block;color:var(--spore);
  }
  .branch h2{
    font-family:var(--display);font-weight:500;
    font-size:clamp(24px,3.4vw,34px);letter-spacing:-.01em;line-height:1.2;
  }
  .branch h2 a{text-decoration:none;border-bottom:1px solid var(--oxblood);padding-bottom:2px}
  .branch h2 a:hover{color:var(--spore);border-color:var(--spore)}
  .branch p{margin-top:14px;max-width:58ch;color:var(--mycelium-dim);font-size:16px}

  .attrs{
    display:flex;flex-wrap:wrap;gap:8px 10px;margin-top:20px;
    font-family:var(--mono);font-size:11px;letter-spacing:.05em;
  }
  .attr{
    border:1px solid var(--hairline);border-radius:2px;
    padding:4px 9px;color:var(--mycelium-dim);
  }
  .attr b{color:var(--mycelium-faint);font-weight:400}

  /* ---------- deployments ---------- */
  .deploys{margin-top:26px;border-top:1px solid var(--hairline)}
  .deploy{
    display:flex;align-items:baseline;justify-content:space-between;gap:16px;
    padding:15px 0;border-bottom:1px solid var(--hairline);
  }
  .deploy-name{font-size:15.5px}
  .deploy-name a{text-decoration:none;border-bottom:1px solid var(--hairline)}
  .deploy-name a:hover{color:var(--spore);border-color:var(--spore)}
  .deploy-name span{
    display:block;font-family:var(--mono);font-size:10.5px;
    color:var(--mycelium-faint);letter-spacing:.05em;margin-top:4px;
  }
  .status{
    font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;
    text-transform:uppercase;white-space:nowrap;display:flex;
    align-items:center;gap:7px;color:var(--mycelium-dim);
  }
  .dot{width:6px;height:6px;border-radius:50%;background:var(--mycelium-faint)}
  .status.live .dot{background:var(--spore);box-shadow:0 0 0 3px rgba(201,162,39,.16)}
  .status.live{color:var(--spore)}

  .research{
    margin-top:22px;display:flex;flex-wrap:wrap;gap:8px;
  }
  .research li{
    list-style:none;font-family:var(--mono);font-size:11.5px;
    border:1px solid var(--hairline);border-radius:2px;padding:6px 11px;
    color:var(--mycelium-dim);
  }
  .note{
    margin-top:18px;font-size:14px;color:var(--mycelium-faint);
    border-left:2px solid var(--hairline);padding-left:14px;max-width:52ch;
  }

  .branch.dormant{opacity:.5;transition:opacity .4s ease}
  .branch.dormant:hover{opacity:.85}

  /* ---------- foot ---------- */
  .foot{
    padding:52px 0 64px;display:flex;flex-wrap:wrap;gap:18px;
    justify-content:space-between;align-items:baseline;
  }
  .foot a{
    font-family:var(--display);font-size:20px;font-weight:500;
    text-decoration:none;border-bottom:1px solid var(--oxblood);
  }
  .foot a:hover{color:var(--spore);border-color:var(--spore)}
  .foot .fine{
    font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;
    color:var(--mycelium-faint);text-transform:uppercase;
  }

  /* ---------- intro sequence ---------- */
  .intro{
    position:fixed;inset:0;z-index:100;
    background:var(--substrate);
    display:flex;align-items:center;justify-content:center;
    opacity:1;transition:opacity 1.1s ease;
  }
  .intro.gone{opacity:0;pointer-events:none}
  .intro-stage{
    position:relative;
    width:min(1180px,94vw);
    display:flex;align-items:center;justify-content:center;
  }
  .intro-stage > svg{width:100%;height:auto;display:block;overflow:visible}
  .scene{
    position:absolute;inset:0;margin:auto;
    width:100%;height:100%;
    display:flex;align-items:center;justify-content:center;
    opacity:0;pointer-events:none;
    transition:opacity .7s ease;
  }
  .scene.on{opacity:1}
  .scene svg{width:100%;height:auto;display:block}

  .skip{
    position:fixed;top:22px;right:24px;z-index:101;
    font-family:var(--mono);font-size:11px;letter-spacing:.16em;
    text-transform:uppercase;color:var(--mycelium-dim);
    background:transparent;border:1px solid var(--hairline);
    border-radius:2px;padding:9px 15px;cursor:pointer;
    transition:color .25s ease,border-color .25s ease,opacity .6s ease;
  }
  .skip:hover{color:var(--spore);border-color:var(--spore)}
  .skip.gone{opacity:0;pointer-events:none}

  .caption{
    position:fixed;left:0;right:0;bottom:52px;z-index:101;
    text-align:center;pointer-events:none;
    font-family:var(--mono);font-size:11px;letter-spacing:.18em;
    text-transform:uppercase;color:var(--mycelium-faint);
    opacity:0;transition:opacity .6s ease;
  }
  .caption.on{opacity:1}
  .caption b{color:var(--spore);font-weight:400}

  body.intro-running{overflow:hidden}
  .page{opacity:1;transition:opacity 1s ease}
  .page.hidden{opacity:0}

  /* scene primitives */
  .cellwall{fill:none;stroke:var(--mycelium-faint);stroke-width:2.5}
  .plasma{fill:none;stroke:var(--spore);stroke-width:1.8}
  .cytoplasm{fill:rgba(232,225,212,.028)}
  .hypha-a{fill:none;stroke:var(--mycelium);stroke-width:3.4;stroke-linecap:round}
  .hypha-thin{fill:none;stroke:var(--mycelium);stroke-width:1.9;stroke-linecap:round}
  .arb{fill:none;stroke:var(--mycelium);stroke-width:1.5;stroke-linecap:round}
  .peri{fill:none;stroke:var(--spore);stroke-width:.9;opacity:.75}
  .scene-label{
    font-family:var(--mono);font-size:11px;letter-spacing:.1em;
    fill:var(--mycelium-faint);text-transform:uppercase;
  }
  .scene-label.hot{fill:var(--spore)}
  .lead{stroke:var(--hairline);stroke-width:.8}
  .root-body{fill:rgba(201,162,39,.05);stroke:var(--spore);stroke-width:1.6}
  .spore-dot{fill:var(--mycelium)}
  .sig-out{fill:none;stroke:var(--spore);stroke-width:1;opacity:.5}
  .sig-in{fill:none;stroke:var(--steel-lit);stroke-width:1;opacity:.5}

  @media (max-width:700px){
    .branch{grid-template-columns:1fr;gap:12px}
    .branch-role{padding-top:0}
    .hero{padding:44px 0 32px}
    .deploy{flex-direction:column;gap:8px}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation:none!important;transition:none!important}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>

<div class="intro" id="intro" hidden>
  <div class="intro-stage" id="stage">

    <!-- SCENE A — the membrane: colonization -->
    <div class="scene" id="sceneA">
      <svg viewBox="0 0 900 520" role="img" aria-label="A fungal hypha penetrates a root cell wall. The plant's plasma membrane invaginates around it without breaking, sheathing the branching arbuscule. Nutrients pass across the interface. The two organisms never fuse.">
        <!-- the root cell -->
        <path class="cytoplasm" d="M330,60 C520,34 760,44 848,92 C876,190 876,336 848,432 C760,482 520,492 330,464 C316,336 316,190 330,60 Z"/>
        <path class="cellwall" id="A_wall" d="M330,60 C520,34 760,44 848,92 C876,190 876,336 848,432 C760,482 520,492 330,464 C316,336 316,190 330,60"/>

        <!-- plasma membrane: continuous, with the invagination already in its geometry -->
        <path class="plasma" id="A_plasma"
          d="M344,74 C520,50 752,60 836,104
             C862,196 862,330 836,420
             C752,468 520,478 344,452
             C338,400 336,340 335,300
             C356,296 372,290 386,282
             C404,272 418,262 436,258
             C452,254 470,256 486,262
             C500,268 512,276 522,282
             C512,258 500,246 486,240
             C470,234 452,236 436,240
             C418,244 404,250 386,244
             C372,238 356,232 335,228
             C336,188 338,128 344,74"/>

        <!-- hypha arriving from outside, horizontal — matches the exchange cord angle -->
        <path class="hypha-a" id="A_hypha" d="M20,262 C110,260 210,262 300,262"/>
        <!-- penetration through the wall -->
        <path class="hypha-a" id="A_pen" d="M300,262 C316,262 330,262 348,262"/>
        <!-- the arbuscule: dichotomous branching inside the cell -->
        <g id="A_arb">
          <path class="arb" d="M348,262 C400,262 440,258 470,250"/>
          <path class="arb" d="M470,250 C510,240 546,214 574,190"/>
          <path class="arb" d="M470,250 C512,262 548,288 574,318"/>
          <path class="arb" d="M574,190 C600,168 626,152 656,142"/>
          <path class="arb" d="M574,190 C596,204 612,222 622,244"/>
          <path class="arb" d="M574,318 C600,342 626,360 658,372"/>
          <path class="arb" d="M574,318 C594,300 610,284 622,268"/>
          <path class="arb" d="M656,142 C678,134 700,130 722,130"/>
          <path class="arb" d="M656,142 C666,158 672,174 674,190"/>
          <path class="arb" d="M658,372 C680,380 702,384 724,384"/>
          <path class="arb" d="M658,372 C668,356 674,340 676,324"/>
          <path class="arb" d="M622,244 C646,248 668,252 690,254"/>
          <path class="arb" d="M622,268 C646,264 668,262 690,260"/>
        </g>
        <!-- periarbuscular membrane: the host's own membrane, wrapping every branch -->
        <g id="A_peri">
          <path class="peri" d="M348,254 C400,254 440,250 468,242 C508,232 544,206 572,182"/>
          <path class="peri" d="M348,270 C400,270 440,266 468,258 C510,270 546,296 572,326"/>
          <path class="peri" d="M572,182 C598,160 624,144 656,134"/>
          <path class="peri" d="M572,326 C598,350 624,368 658,380"/>
        </g>

        <!-- hidden guide for nutrient traffic -->
        <path id="A_guide" fill="none" stroke="none" d="M20,262 C200,262 330,262 470,250 C560,240 620,246 690,254"/>

        <!-- nutrient traffic -->
        <circle class="flow-p" id="p1" r="3" fill="#C9A227" opacity="0"/>
        <circle class="flow-p" id="p2" r="3" fill="#C9A227" opacity="0"/>
        <circle class="flow-c" id="c1" r="3" fill="#8AA6B8" opacity="0"/>
        <circle class="flow-c" id="c2" r="3" fill="#8AA6B8" opacity="0"/>

        <!-- callouts -->
        <g id="A_labels" opacity="0">
          <line class="lead" x1="300" y1="200" x2="300" y2="150"/>
          <text class="scene-label" x="300" y="140" text-anchor="middle">cell wall</text>

          <line class="lead" x1="470" y1="250" x2="470" y2="470"/>
          <text class="scene-label" x="470" y="486" text-anchor="middle">arbuscule</text>

          <line class="lead" x1="700" y1="200" x2="790" y2="200"/>
          <text class="scene-label hot" x="800" y="196" text-anchor="start">periarbuscular</text>
          <text class="scene-label hot" x="800" y="212" text-anchor="start">membrane</text>

          <text class="scene-label" x="120" y="228" text-anchor="middle">hypha</text>
        </g>
      </svg>
    </div>

    <!-- SCENE B — the reach: pre-symbiotic signaling -->
    <div class="scene" id="sceneB">
      <svg viewBox="0 0 900 520" role="img" aria-label="A plant root releases strigolactones. A germinating fungal spore grows toward the signal and branches as it nears. The fungus answers with Myc factors. The two never touch.">
        <!-- signal gradient from the root -->
        <defs>
          <radialGradient id="strig" cx="1" cy="0.5" r="1">
            <stop offset="0%" stop-color="#C9A227" stop-opacity=".22"/>
            <stop offset="55%" stop-color="#C9A227" stop-opacity=".05"/>
            <stop offset="100%" stop-color="#C9A227" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <rect id="B_field" x="0" y="0" width="900" height="520" fill="url(#strig)" opacity="0"/>

        <!-- the root -->
        <path class="root-body" id="B_root" d="M760,40 C800,40 830,70 830,120 L830,400 C830,450 800,480 760,480 C742,480 730,470 730,440 L730,80 C730,50 742,40 760,40 Z"/>
        <text class="scene-label" x="780" y="504" text-anchor="middle">host root</text>

        <!-- strigolactone waves, root -> fungus -->
        <g id="B_sig_out">
          <path class="sig-out" d="M700,140 C640,180 640,340 700,380"/>
          <path class="sig-out" d="M640,120 C560,175 560,345 640,400"/>
          <path class="sig-out" d="M580,104 C480,170 480,350 580,416"/>
        </g>

        <!-- spore + hypha turning toward the signal -->
        <circle class="spore-dot" id="B_spore" cx="70" cy="248" r="6" opacity="0"/>
        <path class="hypha-a" id="B_main" d="M76,248 C150,250 214,254 268,262 C330,272 384,286 432,300"/>
        <g id="B_branch">
          <path class="hypha-thin" d="M432,300 C470,296 500,282 528,264"/>
          <path class="hypha-thin" d="M432,300 C468,314 496,332 520,352"/>
          <path class="hypha-thin" d="M528,264 C552,250 572,240 592,234"/>
          <path class="hypha-thin" d="M528,264 C546,276 558,290 566,304"/>
          <path class="hypha-thin" d="M520,352 C544,366 566,374 586,378"/>
          <path class="hypha-thin" d="M520,352 C540,340 554,328 564,316"/>
          <path class="hypha-thin" d="M592,234 C610,228 626,224 640,222"/>
          <path class="hypha-thin" d="M586,378 C604,382 620,384 634,386"/>
          <path class="hypha-thin" d="M566,304 C586,302 602,300 618,300"/>
          <path class="hypha-thin" d="M564,316 C584,318 600,320 616,322"/>
        </g>

        <!-- Myc factors, fungus -> root -->
        <g id="B_sig_in" opacity="0">
